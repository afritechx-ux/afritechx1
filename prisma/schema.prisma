generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("CLIENT") // "ADMIN" or "CLIENT"
  company       String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  invoices      Invoice[]
  documents     Document[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String     @id @default(uuid())
  name        String
  description String?
  status      String     @default("PENDING") // PENDING, ON_TRACK, AT_RISK, COMPLETED
  progress    Int        @default(0) // 0-100 percentage
  clientId    String
  client      User       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Milestone {
  id          String   @id @default(uuid())
  title       String
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id        String   @id @default(uuid())
  amount    Float
  status    String   @default("UNPAID") // UNPAID, PAID, OVERDUE
  dueDate   DateTime
  clientId  String
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  fileName  String
  fileType  String
  fileUrl   String
  sizeBytes Int
  clientId  String
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
